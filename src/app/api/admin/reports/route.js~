import { prisma } from '@/lib/prisma';
import { auth } from "@clerk/nextjs/server";
import { NextResponse } from 'next/server';

export async function GET(req) {
    try {
        // ✅ Get Clerk user
        const { userId } = auth();

        if (!userId) {
            return NextResponse.json(
                { message: 'Unauthorized' },
                { status: 401 }
            );
        }

        // ✅ Find user in your DB (same as before, but using clerkId)
        const user = await prisma.user.findUnique({
            where: { clerkId: userId }, // 🔥 IMPORTANT: you need this field
        });

        if (!user || user.role !== 'admin') {
            return NextResponse.json(
                { message: 'Forbidden' },
                { status: 403 }
            );
        }

        // 🔥 TOTAL DEUDORES
        const totalDebtors = await prisma.debtor.count();

        // 💰 TOTAL ADEUDADO
        const totalAmount = await prisma.debtor.aggregate({
            _sum: { amountOwed: true }
        });

        // 💸 TOTAL PAGADO
        const totalPaid = await prisma.debtor.aggregate({
            _sum: {
                amountOwed: true
            },
            where: {
                status: 'PAGADO'
            }
        });

        // 📊 AGRUPAR POR STATUS
        const statusCounts = await prisma.debtor.groupBy({
            by: ['status'],
            _count: {
                status: true
            }
        });

        // 🔧 FORMATEAR STATUS
        const formattedStatus = {};
        statusCounts.forEach(item => {
            formattedStatus[item.status] = item._count.status;
        });

        return NextResponse.json({
            totalDebtors,
            totalAmountOwed: totalAmount._sum.amountOwed || 0,
            totalCollected: totalPaid._sum.amountOwed || 0,
            byStatus: formattedStatus
        });

    } catch (err) {
        console.error(err);
        return NextResponse.json(
            { message: 'Server error' },
            { status: 500 }
        );
    }
}