                            <p className="text-sm font-bold group-hover:text-[#443CA3]">
                                Recuperado Hoy
                            </p>

                            <p className="text-2xl font-bold group-hover:text-[#443CA3]">
                                $12,840
                            </p>

                        </div>

                        {/* Floating Card 2 */}
                        <div
                            className="group absolute -bottom-10 -right-10 border border-[#443CA3]/20 p-5 rounded-lg w-56 bg-white animate-floatSlowReverse hover:bg-[#FFFF76] transition-all duration-300">

