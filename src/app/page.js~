                    </p>

                    <div className="flex gap-6 text-[#443CA3]/70">
                        <a href="#">Privacidad</a>
                        <a href="#">Términos</a>
                        <a href="#">Contacto</a>
                    </div>
                </div>
            </footer>
        </div>
    );
