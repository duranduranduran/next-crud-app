'use client';

import Image from "next/image";
import Link from "next/link";
import { useMemo, useState } from "react";

export default function LandingPage() {

    // Particles (static)
    const particles = useMemo(() =>
        [...Array(40)].map(() => ({
            top: Math.random() * 100,
            left: Math.random() * 100,
